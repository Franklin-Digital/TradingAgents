@startuml Class Diagram – Agents & Schemas
title TradingAgents — Agent Classes & Structured Schemas

skinparam classAttributeIconSize 0
skinparam groupInheritance 2
skinparam linetype ortho

' ─── LLM Client Hierarchy ────────────────────────────────────────────────────
package "llm_clients" {
  abstract class BaseLLMClient {
    + provider : str
    + model : str
    + {abstract} chat(messages) : str
    + {abstract} bind_tools(tools) : Runnable
    + {abstract} with_structured_output(schema) : Runnable
  }

  class OpenAIClient {
    + client : ChatOpenAI
    + chat(messages) : str
    + bind_tools(tools) : Runnable
    + with_structured_output(schema) : Runnable
  }

  class AnthropicClient {
    + client : ChatAnthropic
    + chat(messages) : str
    + bind_tools(tools) : Runnable
    + with_structured_output(schema) : Runnable
  }

  class GoogleClient {
    + client : ChatGoogleGenerativeAI
    + thinking_level : str
    + chat(messages) : str
    + bind_tools(tools) : Runnable
    + with_structured_output(schema) : Runnable
  }

  class AzureOpenAIClient {
    + client : AzureChatOpenAI
    + chat(messages) : str
    + bind_tools(tools) : Runnable
    + with_structured_output(schema) : Runnable
  }

  class DeepSeekChatOpenAI {
    + thinking_budget : int
    + chat(messages) : str
  }

  BaseLLMClient <|-- OpenAIClient
  BaseLLMClient <|-- AnthropicClient
  BaseLLMClient <|-- GoogleClient
  BaseLLMClient <|-- AzureOpenAIClient
  OpenAIClient <|-- DeepSeekChatOpenAI
}

' ─── State Models ─────────────────────────────────────────────────────────────
package "agents.utils" {
  class AgentState {
    + messages : list[BaseMessage]
    + company_of_interest : str
    + trade_date : str
    + sender : str
    + market_report : str
    + sentiment_report : str
    + news_report : str
    + fundamentals_report : str
    + investment_plan : str
    + trader_investment_plan : str
    + final_trade_decision : str
    + past_context : str
    + investment_debate_state : InvestDebateState
    + risk_debate_state : RiskDebateState
  }

  class InvestDebateState {
    + bull_history : str
    + bear_history : str
    + history : str
    + current_response : str
    + judge_decision : str
    + count : int
  }

  class RiskDebateState {
    + aggressive_history : str
    + conservative_history : str
    + neutral_history : str
    + history : str
    + latest_speaker : str
    + current_aggressive_response : str
    + current_conservative_response : str
    + current_neutral_response : str
    + judge_decision : str
    + count : int
  }

  class TradingMemoryLog {
    + log_path : Path
    + max_entries : Optional[int]
    + store_decision(ticker, date, signal, decision, reasoning) : None
    + get_pending_entries() : list[dict]
    + get_past_context(ticker) : str
    + batch_update_with_outcomes(updates) : None
  }

  AgentState *-- InvestDebateState
  AgentState *-- RiskDebateState
}

' ─── Structured Output Schemas ────────────────────────────────────────────────
package "agents.schemas" {
  enum PortfolioRating {
    Buy
    Overweight
    Hold
    Underweight
    Sell
  }

  enum TraderAction {
    Buy
    Hold
    Sell
  }

  class ResearchPlan {
    + recommendation : PortfolioRating
    + rationale : str
    + strategic_actions : str
    + render_research_plan() : str
  }

  class TraderProposal {
    + action : TraderAction
    + reasoning : str
    + entry_price : Optional[float]
    + stop_loss : Optional[float]
    + position_sizing : Optional[str]
    + render_trader_proposal() : str
  }

  class PortfolioDecision {
    + rating : PortfolioRating
    + executive_summary : str
    + investment_thesis : str
    + price_target : Optional[float]
    + time_horizon : Optional[str]
    + render_pm_decision() : str
  }

  ResearchPlan --> PortfolioRating
  TraderProposal --> TraderAction
  PortfolioDecision --> PortfolioRating
}


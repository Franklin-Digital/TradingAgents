' ─── Graph Orchestration ──────────────────────────────────────────────────────
package "graph" {
  class TradingAgentsGraph {
    + config : dict
    + deep_thinking_llm : BaseLLMClient
    + quick_thinking_llm : BaseLLMClient
    + tool_nodes : dict[str, ToolNode]
    + graph : CompiledStateGraph
    + memory_log : TradingMemoryLog
    + propagate(ticker: str, date: str) : tuple[dict, dict]
    - _run_graph(state: AgentState) : AgentState
    - _resolve_pending_entries(ticker: str, date: str) : None
    - _log_state(state: dict) : None
    - reflect_and_remember(ticker, date, signal, decision) : None
  }

  class GraphSetup {
    + config : dict
    + analysts : list[str]
    + create_workflow(agents, tool_nodes, conditional_logic) : StateGraph
  }

  class ConditionalLogic {
    + config : dict
    + should_continue_market(state) : str
    + should_continue_social(state) : str
    + should_continue_news(state) : str
    + should_continue_fundamentals(state) : str
    + should_continue_debate(state) : str
    + should_continue_risk_analysis(state) : str
  }

  class Propagator {
    + config : dict
    + create_initial_state(ticker, date, past_context) : AgentState
  }

  class Reflector {
    + llm : BaseLLMClient
    + reflect_on_final_decision(decision, outcome) : str
  }

  class SignalProcessor {
    + process_signal(state: AgentState) : str
  }

  TradingAgentsGraph *-- GraphSetup
  TradingAgentsGraph *-- ConditionalLogic
  TradingAgentsGraph *-- Propagator
  TradingAgentsGraph *-- Reflector
  TradingAgentsGraph *-- SignalProcessor
  TradingAgentsGraph *-- TradingMemoryLog
  TradingAgentsGraph --> BaseLLMClient
}

